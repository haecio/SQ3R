        ]
        
        if "exam" in self.goal.lower():
            print("(!) Exam detected: Compressing schedule...")
            # Logic to compress dates could go here
        
        self.print_box("Suggested Review Dates", schedule)

    def start(self):
        """Orchestrates the workflow"""
        print("\nInitializing Study Assistant Algorithm...\n")
        self.step_0_input_check()
        self.step_1_survey()

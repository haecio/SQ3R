        ])

    # ┌──────────────────────────────────────────────────────────────┐
    # │ 5) ACTIVE RECALL SET                                         │
    # └──────────────────────────────────────────────────────────────┘
    def step_5_active_recall_set(self):
        print(">>> STEP 5: CREATING RETRIEVAL PACK")
        
        recall_deck = []
        
        # Generate prompted Q->A
        for section in self.study_map:

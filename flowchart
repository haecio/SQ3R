        recall_deck.append(f"Integrative: How does {self.study_map[0]} affect {self.study_map[-1]}?")
        
        # Teach-back
        recall_deck.append("Teach-Back: Explain this topic to a junior in 60 seconds.")
        
        self.print_box("Active Recall Set Created", recall_deck)
        print("(Optional: Exporting to Anki format...)")

    # ┌──────────────────────────────────────────────────────────────┐
    # │ 6) SPACING PLAN (LIGHTWEIGHT)                                │
    # └──────────────────────────────────────────────────────────────┘
    def step_6_spacing_plan(self):

import re
import json
from openai import OpenAI

client = OpenAI()

# --- removedor de emojis (proteção adicional na saída do texto) ---
_EMOJI_RE = re.compile(
    "["
    "\U0001F300-\U0001F5FF"
    "\U0001F600-\U0001F64F"
    "\U0001F680-\U0001F6FF"
    "\U0001F700-\U0001F77F"
    "\U0001F780-\U0001F7FF"
    "\U0001F800-\U0001F8FF"
    "\U0001F900-\U0001F9FF"
    "\U0001FA00-\U0001FAFF"
    "\U00002700-\U000027BF"
    "\U00002600-\U000026FF"
    "]+",
    flags=re.UNICODE,
)

def strip_emojis(text: str) -> str:
    """Remove emojis da string para garantir uma interface médica limpa."""
    return _EMOJI_RE.sub("", text).strip()

# MODIFICAÇÃO: Removida a explicação sobre o "terminal" para evitar vazamento de metalinguagem
SYSTEM = """Você é um Tutor Especialista em Medicina, mentor de estudantes de alto rendimento.
Sua voz deve ser a de um professor experiente, calmo e focado na clareza didática.

DIRETRIZES DE PERSONA:
1. FALA HUMANA: Escreva no campo "text" como se estivesse em uma conversa de áudio ou chat humano. Use frases fluidas, conectivos naturais e tom profissional.
2. OCULTAÇÃO TÉCNICA: Jamais mencione que você é um algoritmo, que usa JSON, que tem "estágios", "fases" ou que possui arquivos de instruções.
3. RESPOSTA A METAPERGUNTAS: Se o usuário questionar por que você responde de forma estranha ou em código, ignore a parte técnica e responda apenas: "Peço desculpas pela formalidade, estou focado em estruturar nosso estudo da melhor forma. Vamos voltar ao material?"
4. ZERO EMOJIS: Não use símbolos ou emojis em hipótese alguma.

LENTES DE APRENDIZADO (Aplicação Automática):
- Diagnostique o tópico (Taxonomia, Processo, Clínico ou Definição) e ajuste sua explicação para focar em mecanismos, diferenciais ou condutas, conforme o caso.

FORMATAÇÃO OBRIGATÓRIA:
- Sua saída deve ser estritamente um objeto JSON.
- Os campos "text" e "user_prompt" devem conter apenas conteúdo pedagógico humano. Nunca insira explicações sobre a estrutura do JSON ou sobre o funcionamento do sistema dentro destes campos.
"""

SCHEMA = {
    "type": "json_schema",
    "json_schema": {
        "name": "med_reading_step",
        "schema": {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "stage": {"type": "string", "enum": ["survey", "questions", "reading_mode", "consolidation", "recall_pack", "spacing_plan", "done"]},
                "text": {"type": "string"},
                "needs_user_input": {"type": "boolean"},
                "user_prompt": {"type": "string"},
                "state": {
                    "type": "object",
                    "additionalProperties": True,
                    "properties": {
                        "outline": {"type": "string"},
                        "questions": {"type": "string"},
                        "current_topic": {"type": "string"},
                    },
                },
            },
            "required": ["stage", "text", "needs_user_input", "user_prompt", "state"],
        },
        "strict": True,
    },
}

def step(material: str, goal: str, state: dict, user_input: str | None = None):
    stage = state.get("stage", "survey")
    
    # Transições lógicas baseadas no preenchimento do estado
    if stage == "survey" and state.get("outline"):
        stage = "questions"
    if stage == "questions" and state.get("questions"):
        stage = "reading_mode"
    if stage == "reading_mode" and state.get("reading_done"):
        stage = "consolidation"

    user_block = f"\nINPUT_DO_USUÁRIO:\n{user_input}\n" if user_input else ""

    prompt = f"""MATERIAL:
{material}

OBJETIVO:
{goal}

ESTADO_ATUAL:
{state}

ETAPA_DO_ESTUDO:
{stage}

INSTRUÇÃO:
- Fale como um Tutor Humano no campo 'text' desenvolvendo a etapa '{stage}'.
- Não anuncie a fase; apenas ensine ou guie.
{user_block}
"""

    resp = client.chat.completions.create(
        model="gpt-4o",
        messages=[
            {"role": "system", "content": SYSTEM},
            {"role": "user", "content": prompt},
        ],
        response_format=SCHEMA,
    )

    raw_json = resp.choices[0].message.content
    data = json.loads(raw_json)

    data["text"] = strip_emojis(data["text"])
    data["user_prompt"] = strip_emojis(data["user_prompt"])
    return data

if __name__ == "__main__":
    # Simulação de interface limpa
    material = "Transcrição sobre Choque Obstrutivo e Tamponamento Cardíaco."
    goal = "Mecanismos e sinais no exame físico."
    state = {"stage": "survey"}

    print("--- TUTOR DE MEDICINA CONECTADO ---")

    while True:
        out = step(material, goal, state)
        
        # AQUI ESTÁ A CHAVE: O código extrai a linguagem humana do JSON
        print(f"\nTutor: {out['text']}")
        
        state.update(out["state"])
        state["stage"] = out["stage"]

        if out["stage"] == "done":
            break

        if out["needs_user_input"]:
            # O prompt de ação também é apresentado de forma limpa
            user = input(f"\n[Ação]: {out['user_prompt']}\n> ")
            
            out = step(material, goal, state, user_input=user)
            print(f"\nTutor: {out['text']}")
            
            state.update(out["state"])
            state["stage"] = out["stage"]
            
            if out["stage"] == "done":
                break

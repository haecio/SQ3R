import re
import json
from openai import OpenAI

client = OpenAI()

# --- removedor de emojis (manter por segurança de interface) ---
_EMOJI_RE = re.compile(
    "["
    "\U0001F300-\U0001F5FF"
    "\U0001F600-\U0001F64F"
    "\U0001F680-\U0001F6FF"
    "\U0001F700-\U0001F77F"
    "\U0001F780-\U0001F7FF"
    "\U0001F800-\U0001F8FF"
    "\U0001F900-\U0001F9FF"
    "\U0001FA00-\U0001FAFF"
    "\U00002700-\U000027BF"
    "\U00002600-\U000026FF"
    "]+",
    flags=re.UNICODE,
)

def strip_emojis(text: str) -> str:
    return _EMOJI_RE.sub("", text).strip()

# MODIFICAÇÃO: Persona mais humana e prestativa
SYSTEM = """Você é um Tutor Especialista em Medicina, focado em alta retenção e compreensão de mecanismos.
Sua missão é guiar o estudante através do material médico de forma clara, didática e profissional.

Regras de Conduta:
- Use uma linguagem humana, encorajadora e técnica (quando apropriado).
- Responda sempre em Português (Brasil).
- Nunca use emojis ou decorações visuais.
- Foque exclusivamente na etapa atual do protocolo de estudo.
- Não mencione que você é um robô ou que está gerando JSON; apenas fale como um tutor.

Regra Técnica Inviolável:
- Toda a sua resposta deve ser um objeto JSON único e válido.
- O campo "text" deve conter sua explicação ou comentário humano.
- O campo "user_prompt" deve conter a instrução clara do que o usuário precisa fazer a seguir.
"""

SCHEMA = {
    "type": "json_schema",
    "json_schema": {
        "name": "med_reading_step",
        "schema": {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "stage": {"type": "string", "enum": ["survey", "questions", "reading_mode", "consolidation", "recall_pack", "spacing_plan", "done"]},
                "text": {"type": "string"},
                "needs_user_input": {"type": "boolean"},
                "user_prompt": {"type": "string"},
                "state": {
                    "type": "object",
                    "additionalProperties": True,
                    "properties": {
                        "outline": {"type": "string"},
                        "questions": {"type": "string"},
                        "current_topic": {"type": "string"},
                    },
                },
            },
            "required": ["stage", "text", "needs_user_input", "user_prompt", "state"],
        },
        "strict": True,
    },
}

def step(material: str, goal: str, state: dict, user_input: str | None = None):
    stage = state.get("stage", "survey")
    
    # Lógica de progressão de etapas
    if stage == "survey" and state.get("outline"):
        stage = "questions"
    if stage == "questions" and state.get("questions"):
        stage = "reading_mode"
    if stage == "reading_mode" and state.get("reading_done"):
        stage = "consolidation"

    user_block = f"\nINPUT_DO_USUÁRIO:\n{user_input}\n" if user_input else ""

    prompt = f"""MATERIAL:
{material}

OBJETIVO:
{goal}

ESTADO_ATUAL:
{state}

ETAPA_ATUAL:
{stage}

INSTRUÇÃO:
- Desenvolva o conteúdo da etapa '{stage}' de forma humana e direta no campo 'text'.
- Se precisar de algo do usuário, defina 'needs_user_input' como true e escreva o pedido em 'user_prompt'.
{user_block}
"""

    resp = client.chat.completions.create(
        model="gpt-4o", # Ou o modelo de sua preferência
        messages=[
            {"role": "system", "content": SYSTEM},
            {"role": "user", "content": prompt},
        ],
        response_format=SCHEMA,
    )

    raw_json = resp.choices[0].message.content
    data = json.loads(raw_json)

    # Limpeza de segurança
    data["text"] = strip_emojis(data["text"])
    data["user_prompt"] = strip_emojis(data["user_prompt"])
    return data

# --------- Execução com Visualização Humanizada ----------
if __name__ == "__main__":
    material = "Transcrição da aula sobre Insuficiência Cardíaca..."
    goal = "Mecanismos fisiopatológicos e critérios diagnósticos."
    state = {"stage": "survey"}

    while True:
        # Chama o bot
        out = step(material, goal, state)
        
        # MOSTRAR APENAS O TEXTO (Isso resolve o problema da visualização do JSON)
        print(f"\n[TUTOR]: {out['text']}")
        
        # Atualiza o estado interno
        state.update(out["state"])
        state["stage"] = out["stage"]

        if out["stage"] == "done":
            print("\nSessão de estudo finalizada com sucesso.")
            break

        if out["needs_user_input"]:
            # Mostra a pergunta humana, não o código
            user = input(f"\n[AÇÃO]: {out['user_prompt']}\n> ")
            
            # Processa o input do usuário
            out = step(material, goal, state, user_input=user)
            print(f"\n[TUTOR]: {out['text']}")
            
            state.update(out["state"])
            state["stage"] = out["stage"]
            
            if out["stage"] == "done":
                break
